# Copy this file to .env and fill in your own values.
# See docs/SELF_HOSTING.md for how to obtain each credential.

# MySQL-compatible database. TiDB Cloud's free serverless tier works well --
# create a cluster, then use its connection string here (mysql+pymysql://...).
DATABASE_URL=mysql+pymysql://user:password@host:4000/docsync
# Most managed MySQL (including TiDB Cloud) requires TLS. Set to false for a
# plain local MySQL install with no TLS configured.
DATABASE_SSL=true

# Confluence: Settings -> Personal Access Tokens (or API tokens, depending on
# your Atlassian plan) at https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net
CONFLUENCE_API_TOKEN=
CONFLUENCE_EMAIL=you@example.com
# The Confluence page ID under which each onboarded repo's page gets created.
# Open the page in Confluence and read the numeric ID out of the URL.
CONFLUENCE_ROOT_PAGE_ID=

# GitHub MCP: a hosted remote MCP server address plus a GitHub PAT with repo
# read scope (contents:read, metadata:read) for the repos you'll be syncing.
GITHUB_MCP_SERVER_URL=https://api.githubcopilot.com/mcp/
GITHUB_MCP_TOKEN=

# LLM used for naming/content generation.
DEEPSEEK_API_KEY=

# Shared secret configured on the GitHub webhook (Settings -> Webhooks) for
# this repo. Generate one with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# Comma-separated list of origins allowed to call this API (your frontend's
# deployed URL). Defaults to the local Vite dev server if unset.
CORS_ALLOWED_ORIGINS=http://localhost:5173
