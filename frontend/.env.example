# Copy this file to .env and fill in your own values.
# Optional for local dev -- Vite's dev server proxies /api to
# http://localhost:8000 by default (see vite.config.js), so this can stay
# unset while developing against a locally-running backend.
#
# Required for a production build (e.g. deploying to Vercel) where the
# frontend and backend live on different hosts. Set it to your deployed
# backend's origin, with NO /api suffix and no trailing slash -- the dev
# proxy strips /api before forwarding, so the backend's real routes
# (/repos, /webhooks/github, ...) have no /api prefix.
VITE_API_BASE_URL=https://your-backend-host.example.com
